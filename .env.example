# Vite/React 子项目与静态页共用：填好后运行 npm run sync-supabase-config 生成根目录 config.js
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# 可选别名（sync 脚本同样识别）
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# ── 每日 RSS 新闻写入 news_items（npm run sync-daily-news）──
# 在 Supabase Dashboard → Project Settings → API 复制 service_role（仅服务器/CI 使用，勿写进前端）
# SUPABASE_SERVICE_ROLE_KEY=
# 可选：自定义 RSS，英文逗号分隔；不填则使用内置 BBC / The Verge / TechCrunch
# NEWS_RSS_URLS=
